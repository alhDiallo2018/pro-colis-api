generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  client
  driver
  admin
  super_admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum DriverStatus {
  available
  busy
  offline
}

enum ParcelStatus {
  pending
  free
  confirmed
  picked_up
  in_transit
  arrived
  out_for_delivery
  delivered
  cancelled
}

enum ParcelType {
  document
  package
  fragile
  perishable
  valuable
}

enum BidStatus {
  pending
  accepted
  rejected
}

enum MediaType {
  photo
  video
  audio
  signature
  proof
}

enum PaymentMethod {
  wave
  freemMoney
  orange_money
  card
  cash
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum NotificationPriority {
  low
  normal
  high
  urgent
}

enum AdvertisementStatus {
  open
  closed
  cancelled
}

enum SupportStatus {
  open
  pending
  closed
}

enum IdentityStatus {
  pending
  approved
  rejected
}

enum BackupStatus {
  pending
  running
  completed
  failed
}

enum WalletStatus {
  active
  suspended
}

enum WalletTransactionType {
  deposit
  commission
  bonus
  adjustment
  refund
  correction
  penalty
  withdrawal
}

enum CommissionProfileType {
  local
  regional
  express
  international
}

enum WithdrawalStatus {
  pending
  processing
  completed
  failed
  cancelled
}

model User {
  id                   String                 @id @default(uuid()) @db.Uuid
  email                String?                @unique
  phone                String                 @unique
  fullName             String                 @map("full_name")
  passwordHash         String?                @map("password_hash")
  pinHash              String?                @map("pin_hash")
  role                 UserRole
  status               UserStatus             @default(active)
  profilePhoto         String?                @map("profile_photo")
  address              String?
  city                 String?
  region               String?
  gender               String?
  garageId             String?                @map("garage_id") @db.Uuid
  driverStatus         DriverStatus?          @map("driver_status")
  rating               Decimal                @default(0) @db.Decimal(3, 2)
  totalDeliveries      Int                    @default(0) @map("total_deliveries")
  completedDeliveries  Int                    @default(0) @map("completed_deliveries")
  cancelledDeliveries  Int                    @default(0) @map("cancelled_deliveries")
  isEmailVerified      Boolean                @default(false) @map("is_email_verified")
  isPhoneVerified      Boolean                @default(false) @map("is_phone_verified")
  isProfileComplete    Boolean                @default(false) @map("is_profile_complete")
  lastLogin            DateTime?              @map("last_login") @db.Timestamptz
  lastActiveAt         DateTime?              @map("last_active_at") @db.Timestamptz
  deletedAt            DateTime?              @map("deleted_at") @db.Timestamptz
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz
  garage               Garage?                @relation(fields: [garageId], references: [id], onDelete: SetNull)
  vehicles             Vehicle[]              @relation("DriverVehicles")
  sentParcels          Parcel[]               @relation("ParcelSender")
  drivenParcels        Parcel[]               @relation("ParcelDriver")
  createdParcels       Parcel[]               @relation("ParcelCreator")
  cancelledParcels     Parcel[]               @relation("ParcelCanceller")
  bids                 Bid[]
  parcelEvents         ParcelEvent[]
  parcelMedia          ParcelMedia[]
  payments             Payment[]              @relation("PaymentUser")
  validatedPayments    Payment[]              @relation("PaymentValidator")
  score                Score?
  scoreTransactions    ScoreTransaction[]
  notifiedTransactions ScoreTransaction[]  @relation("ScorePerformer")
  notifications        Notification[]          @relation("NotificationRecipient")
  sentNotifications    Notification[]          @relation("NotificationSender")
  otpCodes             OtpCode[]
  refreshTokens        RefreshToken[]
  advertisements       Advertisement[]
  advertisementOffers  AdvertisementOffer[]
  driverLocations      DriverLocation[]
  ratingsGiven         Rating[]                @relation("RatingAuthor")
  ratingsReceived      Rating[]                @relation("RatingDriver")
  supportMessages      SupportMessage[]
  identityVerifications IdentityVerification[] @relation("IdentityOwner")
  reviewedIdentities   IdentityVerification[]  @relation("IdentityReviewer")
  favoriteGarages      FavoriteGarage[]
  addresses            Address[]
  sentMessages         Message[]               @relation("MessageSender")
  receivedMessages     Message[]               @relation("MessageReceiver")
  auditLogs            AuditLog[]              @relation("AuditActor")
  systemConfigs        SystemConfig[]
  webhooks             Webhook[]
  backups              Backup[]
  wallet               Wallet?
  walletTransactions   WalletTransaction[]
  withdrawals          Withdrawal[]

  @@map("users")
}

model Garage {
  id                 String           @id @default(uuid()) @db.Uuid
  name               String
  city               String
  region             String
  address            String?
  phone              String?
  latitude           Decimal?         @db.Decimal(10, 7)
  longitude          Decimal?         @db.Decimal(10, 7)
  isActive           Boolean          @default(true) @map("is_active")
  deletedAt          DateTime?        @map("deleted_at") @db.Timestamptz
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  users              User[]
  vehicles           Vehicle[]
  departureParcels   Parcel[]         @relation("DepartureGarage")
  arrivalParcels     Parcel[]         @relation("ArrivalGarage")
  departingAds       Advertisement[]  @relation("AdvertisementDepartureGarage")
  arrivingAds        Advertisement[]  @relation("AdvertisementArrivalGarage")
  favoriteBy         FavoriteGarage[]

  @@index([isActive])
  @@map("garages")
}

model Vehicle {
  id          String    @id @default(uuid()) @db.Uuid
  plateNumber String    @unique @map("plate_number")
  model       String
  type        String
  capacity    Int       @default(0)
  garageId    String?   @map("garage_id") @db.Uuid
  driverId    String?   @map("driver_id") @db.Uuid
  isAvailable Boolean   @default(true) @map("is_available")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  garage      Garage?   @relation(fields: [garageId], references: [id])
  driver      User?     @relation("DriverVehicles", fields: [driverId], references: [id], onDelete: SetNull)

  @@map("vehicles")
}

model Parcel {
  id                    String             @id @default(uuid()) @db.Uuid
  trackingNumber        String             @unique @map("tracking_number")
  senderId              String?            @map("sender_id") @db.Uuid
  senderName            String             @map("sender_name")
  senderPhone           String             @map("sender_phone")
  senderEmail           String?            @map("sender_email")
  receiverName          String             @map("receiver_name")
  receiverPhone         String             @map("receiver_phone")
  receiverEmail         String?            @map("receiver_email")
  receiverAddress       String?            @map("receiver_address")
  description           String
  weight                Decimal            @db.Decimal(10, 2)
  length                Decimal?           @db.Decimal(10, 2)
  width                 Decimal?           @db.Decimal(10, 2)
  height                Decimal?           @db.Decimal(10, 2)
  type                  ParcelType         @default(package)
  status                ParcelStatus       @default(pending)
  departureGarageId     String             @map("departure_garage_id") @db.Uuid
  arrivalGarageId       String?            @map("arrival_garage_id") @db.Uuid
  driverId              String?            @map("driver_id") @db.Uuid
  price                 Decimal?           @db.Decimal(12, 2)
  proposedPrice         Decimal?           @map("proposed_price") @db.Decimal(12, 2)
  negotiatedPrice       Decimal?           @map("negotiated_price") @db.Decimal(12, 2)
  deliveryFees          Decimal?           @map("delivery_fees") @db.Decimal(12, 2)
  totalAmount           Decimal?           @map("total_amount") @db.Decimal(12, 2)
  isInsured             Boolean            @default(false) @map("is_insured")
  insuranceAmount       Decimal?           @map("insurance_amount") @db.Decimal(12, 2)
  isUrgent              Boolean            @default(false) @map("is_urgent")
  urgentFee             Decimal?           @map("urgent_fee") @db.Decimal(12, 2)
  isFreeForBidding      Boolean            @default(false) @map("is_free_for_bidding")
  selectedBidId         String?            @map("selected_bid_id") @db.Uuid
  paymentMethod         PaymentMethod?     @map("payment_method")
  paymentPhoneNumber    String?            @map("payment_phone_number")
  paymentStatus         String?            @map("payment_status")
  signatureUrl          String?            @map("signature_url")
  notes                 String?
  pickupDate            DateTime?          @map("pickup_date") @db.Timestamptz
  deliveryDate          DateTime?          @map("delivery_date") @db.Timestamptz
  estimatedDeliveryDate DateTime?          @map("estimated_delivery_date") @db.Timestamptz
  createdBy             String?            @map("created_by") @db.Uuid
  cancelledBy           String?            @map("cancelled_by") @db.Uuid
  cancellationReason    String?            @map("cancellation_reason")
  cancelledAt           DateTime?          @map("cancelled_at") @db.Timestamptz
  deletedAt             DateTime?          @map("deleted_at") @db.Timestamptz
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  sender                User?              @relation("ParcelSender", fields: [senderId], references: [id], onDelete: SetNull)
  driver                User?              @relation("ParcelDriver", fields: [driverId], references: [id], onDelete: SetNull)
  creator               User?              @relation("ParcelCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  canceller             User?              @relation("ParcelCanceller", fields: [cancelledBy], references: [id], onDelete: SetNull)
  departureGarage       Garage             @relation("DepartureGarage", fields: [departureGarageId], references: [id])
  arrivalGarage         Garage?            @relation("ArrivalGarage", fields: [arrivalGarageId], references: [id])
  selectedBid           Bid?               @relation("SelectedBid", fields: [selectedBidId], references: [id], onDelete: SetNull)
  bids                  Bid[]              @relation("ParcelBids")
  events                ParcelEvent[]
  media                 ParcelMedia[]
  payments              Payment[]
  scoreTransactions     ScoreTransaction[]
  walletTransactions    WalletTransaction[]
  notifications         Notification[]
  advertisementOffers   AdvertisementOffer[]
  driverLocations       DriverLocation[]
  ratings               Rating[]
  messages              Message[]

  @@index([senderId])
  @@index([driverId])
  @@index([status])
  @@index([trackingNumber])
  @@index([departureGarageId])
  @@index([arrivalGarageId])
  @@map("parcels")
}

model Bid {
  id              String         @id @default(uuid()) @db.Uuid
  parcelId        String         @map("parcel_id") @db.Uuid
  driverId        String         @map("driver_id") @db.Uuid
  price           Decimal        @db.Decimal(12, 2)
  message         String?
  status          BidStatus      @default(pending)
  responseMessage String?        @map("response_message")
  audioUrl        String?        @map("audio_url")
  respondedAt     DateTime?      @map("responded_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  parcel          Parcel         @relation("ParcelBids", fields: [parcelId], references: [id], onDelete: Cascade)
  driver          User           @relation(fields: [driverId], references: [id], onDelete: Cascade)
  selectedParcels Parcel[]       @relation("SelectedBid")
  notifications   Notification[]

  @@unique([parcelId, driverId])
  @@index([parcelId])
  @@index([driverId])
  @@map("bids")
}

model ParcelEvent {
  id          String   @id @default(uuid()) @db.Uuid
  parcelId    String   @map("parcel_id") @db.Uuid
  status      String
  description String
  location    String?
  locationLat Decimal? @map("location_lat") @db.Decimal(10, 7)
  locationLng Decimal? @map("location_lng") @db.Decimal(10, 7)
  userId      String?  @map("user_id") @db.Uuid
  userName    String?  @map("user_name")
  userRole    String?  @map("user_role")
  photoUrl    String?  @map("photo_url")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  parcel      Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([parcelId, createdAt])
  @@map("parcel_events")
}

model ParcelMedia {
  id              String    @id @default(uuid()) @db.Uuid
  parcelId        String    @map("parcel_id") @db.Uuid
  uploadedBy      String?   @map("uploaded_by") @db.Uuid
  mediaType       MediaType @map("media_type")
  url             String
  filename        String?
  mimeType        String?   @map("mime_type")
  sizeBytes       BigInt?   @map("size_bytes")
  durationSeconds Int?      @map("duration_seconds")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  parcel          Parcel    @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  uploader        User?     @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@map("parcel_media")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  parcelId      String?       @map("parcel_id") @db.Uuid
  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("XOF")
  method        PaymentMethod
  status        PaymentStatus @default(pending)
  transactionId String?       @unique @map("transaction_id")
  phoneNumber   String?       @map("phone_number")
  reference     String?       @unique
  metadata      Json          @default("{}")
  receiptUrl    String?       @map("receipt_url")
  validatedBy   String?       @map("validated_by") @db.Uuid
  validatedAt   DateTime?     @map("validated_at") @db.Timestamptz
  completedAt   DateTime?     @map("completed_at") @db.Timestamptz
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  user          User          @relation("PaymentUser", fields: [userId], references: [id])
  parcel        Parcel?       @relation(fields: [parcelId], references: [id], onDelete: SetNull)
  validator     User?         @relation("PaymentValidator", fields: [validatedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([parcelId])
  @@map("payments")
}

model Score {
  userId      String   @id @map("user_id") @db.Uuid
  points      Int      @default(0)
  totalEarned Int      @default(0) @map("total_earned")
  totalSpent  Int      @default(0) @map("total_spent")
  lastUpdated DateTime @default(now()) @map("last_updated") @db.Timestamptz
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scores")
}

model ScoreTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  amount      Int
  type        String
  source      String?
  parcelId    String?  @map("parcel_id") @db.Uuid
  description String
  status      String   @default("completed")
  performedBy String?  @map("performed_by") @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parcel      Parcel?  @relation(fields: [parcelId], references: [id], onDelete: SetNull)
  actor       User?    @relation("ScorePerformer", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("score_transactions")
}

model Wallet {
  userId          String               @id @map("user_id") @db.Uuid
  balance         Decimal              @default(0) @db.Decimal(12, 2)
  pendingBalance  Decimal              @default(0) @map("pending_balance") @db.Decimal(12, 2)
  totalDeposited  Decimal              @default(0) @map("total_deposited") @db.Decimal(12, 2)
  totalSpent      Decimal              @default(0) @map("total_spent") @db.Decimal(12, 2)
  totalRefunded   Decimal              @default(0) @map("total_refunded") @db.Decimal(12, 2)
  totalWithdrawn   Decimal             @default(0) @map("total_withdrawn") @db.Decimal(12, 2)
  totalCommissionsPaid Decimal        @default(0) @map("total_commissions_paid") @db.Decimal(12, 2)
  status          WalletStatus         @default(active)
  lastDepositAt   DateTime?            @map("last_deposit_at") @db.Timestamptz
  lastActivityAt  DateTime?            @map("last_activity_at") @db.Timestamptz
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]
  withdrawals     Withdrawal[]

  @@map("wallets")
}

model WalletTransaction {
  id           String                @id @default(uuid()) @db.Uuid
  walletUserId String                @map("wallet_user_id") @db.Uuid
  type         WalletTransactionType
  amount       Decimal               @db.Decimal(12, 2)
  balanceBefore Decimal              @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal              @map("balance_after") @db.Decimal(12, 2)
  parcelId     String?               @map("parcel_id") @db.Uuid
  description  String?
  origin       String?
  status       String                @default("completed")
  performedBy  String?               @map("performed_by") @db.Uuid
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz
  wallet       Wallet                @relation(fields: [walletUserId], references: [userId], onDelete: Cascade)
  parcel       Parcel?               @relation(fields: [parcelId], references: [id], onDelete: SetNull)
  admin        User?                 @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([walletUserId, createdAt])
  @@map("wallet_transactions")
}

model Withdrawal {
  id                String           @id @default(uuid()) @db.Uuid
  walletUserId      String           @map("wallet_user_id") @db.Uuid
  amount            Decimal          @db.Decimal(12, 2)
  method            String           @default("wave")
  phone             String?
  status            WithdrawalStatus @default(pending)
  reference         String?          @unique
  failureReason     String?          @map("failure_reason")
  requestedAt       DateTime         @default(now()) @map("requested_at") @db.Timestamptz
  processedBy       String?          @map("processed_by") @db.Uuid
  processedAt       DateTime?        @map("processed_at") @db.Timestamptz
  completedAt       DateTime?        @map("completed_at") @db.Timestamptz
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  wallet            Wallet           @relation(fields: [walletUserId], references: [userId], onDelete: Cascade)
  processor         User?            @relation(fields: [processedBy], references: [id], onDelete: SetNull)

  @@index([walletUserId, createdAt])
  @@index([status])
  @@map("withdrawals")
}

model CommissionConfig {
  id             String              @id @default(uuid()) @db.Uuid
  profile        CommissionProfileType @default(local)
  percentage     Decimal             @default(5) @db.Decimal(5, 2)
  minAmount      Decimal             @default(100) @map("min_amount") @db.Decimal(12, 2)
  maxAmount      Decimal             @default(500) @map("max_amount") @db.Decimal(12, 2)
  isActive       Boolean             @default(true) @map("is_active")
  effectiveFrom  DateTime            @map("effective_from") @db.Timestamptz
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  @@map("commission_configs")
}

model Notification {
  id         String               @id @default(uuid()) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  parcelId   String?              @map("parcel_id") @db.Uuid
  bidId      String?              @map("bid_id") @db.Uuid
  senderId   String?              @map("sender_id") @db.Uuid
  senderName String?              @map("sender_name")
  type       String
  title      String
  body       String
  data       Json                 @default("{}")
  isRead     Boolean              @default(false) @map("is_read")
  priority   NotificationPriority @default(normal)
  readAt     DateTime?            @map("read_at") @db.Timestamptz
  createdAt  DateTime             @default(now()) @map("created_at") @db.Timestamptz
  user       User                 @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  parcel     Parcel?              @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  bid        Bid?                 @relation(fields: [bidId], references: [id], onDelete: SetNull)
  sender     User?                @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("notifications")
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  codeHash  String   @map("code_hash")
  type      String
  phone     String?
  email     String?
  isUsed    Boolean  @default(false) @map("is_used")
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Advertisement {
  id                String               @id @default(uuid()) @db.Uuid
  driverId          String               @map("driver_id") @db.Uuid
  departureGarageId String?              @map("departure_garage_id") @db.Uuid
  arrivalGarageId   String?              @map("arrival_garage_id") @db.Uuid
  departureCity     String?              @map("departure_city")
  arrivalCity       String?              @map("arrival_city")
  departureAt       DateTime?            @map("departure_at") @db.Timestamptz
  availableWeight   Decimal?             @map("available_weight") @db.Decimal(10, 2)
  proposedPrice     Decimal?             @map("proposed_price") @db.Decimal(12, 2)
  description       String?
  audioUrl          String?              @map("audio_url")
  status            AdvertisementStatus  @default(open)
  metadata          Json                 @default("{}")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  driver            User                 @relation(fields: [driverId], references: [id], onDelete: Cascade)
  departureGarage   Garage?              @relation("AdvertisementDepartureGarage", fields: [departureGarageId], references: [id])
  arrivalGarage     Garage?              @relation("AdvertisementArrivalGarage", fields: [arrivalGarageId], references: [id])
  offers            AdvertisementOffer[]

  @@map("advertisements")
}

model AdvertisementOffer {
  id              String    @id @default(uuid()) @db.Uuid
  advertisementId String    @map("advertisement_id") @db.Uuid
  clientId        String    @map("client_id") @db.Uuid
  parcelId        String?   @map("parcel_id") @db.Uuid
  price           Decimal   @db.Decimal(12, 2)
  message         String?
  status          BidStatus @default(pending)
  responseMessage String?   @map("response_message")
  respondedAt     DateTime? @map("responded_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  client          User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parcel          Parcel?   @relation(fields: [parcelId], references: [id], onDelete: SetNull)

  @@map("advertisement_offers")
}

model DriverLocation {
  id        String   @id @default(uuid()) @db.Uuid
  driverId  String   @map("driver_id") @db.Uuid
  parcelId  String?  @map("parcel_id") @db.Uuid
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  accuracy  Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  driver    User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  parcel    Parcel?  @relation(fields: [parcelId], references: [id], onDelete: SetNull)

  @@index([driverId, createdAt])
  @@map("driver_locations")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  parcelId  String?  @map("parcel_id") @db.Uuid
  driverId  String?  @map("driver_id") @db.Uuid
  ratedBy   String   @map("rated_by") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  parcel    Parcel?  @relation(fields: [parcelId], references: [id], onDelete: SetNull)
  driver    User?    @relation("RatingDriver", fields: [driverId], references: [id], onDelete: Cascade)
  author    User     @relation("RatingAuthor", fields: [ratedBy], references: [id], onDelete: Cascade)

  @@map("ratings")
}

model SupportMessage {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  subject   String?
  message   String
  status    SupportStatus @default(open)
  metadata  Json          @default("{}")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("support_messages")
}

model IdentityVerification {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  status           IdentityStatus @default(pending)
  documentType     String?        @map("document_type")
  documentFrontUrl String?        @map("document_front_url")
  documentBackUrl  String?        @map("document_back_url")
  rejectionReason  String?        @map("rejection_reason")
  reviewedBy       String?        @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime?      @map("reviewed_at") @db.Timestamptz
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  user             User           @relation("IdentityOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewer         User?          @relation("IdentityReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

