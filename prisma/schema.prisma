  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz
  updater   User?    @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("system_configs")
}

model Webhook {
  id        String   @id @default(uuid()) @db.Uuid
