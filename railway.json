{
    "build": {
      "builder": "NIXPACKS",
      "buildCommand": "cd backend && dart pub get"
    },
    "deploy": {
      "startCommand": "cd backend && dart run bin/server.dart",
      "healthcheckPath": "/health",
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
    }
  }