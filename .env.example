NODE_ENV=development
PORT=8080
API_PORT=18081
DATABASE_URL=postgresql://procolis:procolis@postgres:5432/procolis?schema=public
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
OTP_EXPIRES_MINUTES=10
UPLOAD_STORAGE=local
UPLOAD_LOCAL_DIR=uploads
PUBLIC_BASE_URL=http://localhost:18081
LOG_LEVEL=info
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@sendprocolis.com
BREVO_SENDER_NAME=PRO COLIS
BREVO_SMS_SENDER=ProColis

# PayDunya
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_DISBURSE_BASE_URL=https://app.paydunya.com/api/v2/disburse
# Montant minimum encaissement (pay-in) et retrait (pay-out) en XOF
PAYDUNYA_MIN_AMOUNT=200
PAYDUNYA_MIN_WITHDRAWAL=500
# Exiger l'identité vérifiée (KYC) pour enchérir / publier une annonce ("true"/"false")
REQUIRE_DRIVER_VERIFICATION=false
